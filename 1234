/* ===== DASHBOARD ===== */
function renderDash(){
  if(!user)return;
  document.getElementById('dname').textContent=user.name;
  document.getElementById('droom').textContent='ห้อง '+user.room+' • ภาคเรียนที่ 1 ปีการศึกษา 2569';
  setNavs();
  updProgress();
  renderPills(1); renderPills(2);
  updOverview();
}

function setNavs(){
  if(!user)return;
  const init=user.name.charAt(0);
  const fn=user.name.split(' ')[0]||user.name;
  [1,2,3].forEach(i=>{
    const av=document.getElementById('av'+i);
    const nn=document.getElementById('nn'+i);
    if(av)av.textContent=init;
    if(nn)nn.textContent=fn;
  });
}

function updProgress(){
  if(!user)return;
  const u1d=UNITS[1].lessons.filter(l=>user.w.includes(l.id)).length;
  const u2d=UNITS[2].lessons.filter(l=>user.w.includes(l.id)).length;
  document.getElementById('sw').textContent=(u1d+u2d)+'/10';
  document.getElementById('ss').textContent=user.s.length+'/10';
  const scores=Object.values(rubDB[user.id]||{});
  const avg=scores.length?(scores.reduce((a,b)=>a+b,0)/scores.length).toFixed(1):'-';
  document.getElementById('savg').textContent=avg;
  const p1=Math.round(u1d/5*100), p2=Math.round(u2d/5*100);
  document.getElementById('pb1').style.width=p1+'%';
  document.getElementById('pb2').style.width=p2+'%';
  document.getElementById('pt1').textContent=u1d+' / 5 บทเรียน';
  document.getElementById('pt2').textContent=u2d+' / 5 บทเรียน';
  document.getElementById('pp1').textContent=p1+'%';
  document.getElementById('pp2').textContent=p2+'%';
}

function renderPills(u){
  const c=document.getElementById('pills'+u);
  c.innerHTML='';
  UNITS[u].lessons.forEach((l,i)=>{
    const done=user&&user.w.includes(l.id);
    const pill=document.createElement('div');
    pill.className='pill '+(done?'done':'todo');
    pill.textContent=(done?'✅':'📖')+' เรื่อง '+(i+1);
    pill.onclick=e=>{e.stopPropagation();openLesson(u,i);};
    c.appendChild(pill);
  });
}

