<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>บทเรียนออนไลน์ วิทยาการคำนวณ ป.4</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800&family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ===== VARIABLES ===== */
:root {
  --pk1: #fdf2f8; --pk2: #fce7f3; --pk3: #f9a8d4;
  --pk4: #f472b6; --pk5: #ec4899; --pk6: #db2777;
  --bl1: #eff6ff; --bl2: #dbeafe; --bl3: #93c5fd;
  --bl4: #60a5fa; --bl5: #3b82f6; --bl6: #2563eb;
  --wh: #ffffff;
  --g0: #f9fafb; --g1: #f3f4f6; --g2: #e5e7eb;
  --g3: #d1d5db; --g4: #9ca3af; --g5: #6b7280;
  --g6: #4b5563; --g7: #374151; --g8: #1f2937;
  --green: #10b981; --amber: #f59e0b; --red: #ef4444;
  --sh-sm: 0 1px 4px rgba(0,0,0,.06);
  --sh-md: 0 4px 20px rgba(0,0,0,.08);
  --sh-lg: 0 12px 48px rgba(0,0,0,.12);
  --sh-pk: 0 8px 32px rgba(236,72,153,.20);
  --sh-bl: 0 8px 32px rgba(59,130,246,.18);
  --r-sm: 10px; --r-md: 16px; --r-lg: 24px; --r-xl: 32px;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Noto Sans Thai', 'Prompt', sans-serif;
  background: #f5f0fa;
  color: var(--g8); font-size: 15px; line-height: 1.7;
  min-height: 100vh;
}

/* ===== PAGE SYSTEM ===== */
.page { display: none; min-height: 100vh; animation: fadeIn .35s ease; }
.page.active { display: block; }
#page-login.active { display: flex; }

@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
@keyframes slideUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.04)} }

/* ===== NAVBAR ===== */
.navbar {
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--g2);
  height: 60px; padding: 0 24px;
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 200;
  box-shadow: var(--sh-sm);
}
.nav-brand {
  display: flex; align-items: center; gap: 10px;
  cursor: pointer; text-decoration: none;
  font-weight: 700; font-size: 15px; color: var(--g8);
}
.nav-logo {
  width: 34px; height: 34px; border-radius: 10px;
  background: linear-gradient(135deg, var(--pk5), var(--bl5));
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; box-shadow: var(--sh-pk);
}
.nav-right { display: flex; align-items: center; gap: 10px; }
.nav-user { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--g6); }
.nav-avatar {
  width: 30px; height: 30px; border-radius: 50%;
  background: linear-gradient(135deg, var(--pk3), var(--bl3));
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; color: var(--wh);
}
.btn-out {
  padding: 5px 14px; border: 1.5px solid var(--g2);
  border-radius: 8px; background: var(--wh);
  font-family: inherit; font-size: 13px; color: var(--g6);
  cursor: pointer; transition: all .2s;
}
.btn-out:hover { background: var(--g0); border-color: var(--g3); }

/* ===== LOGIN PAGE ===== */
#page-login {
  min-height: 100vh;
  background: linear-gradient(135deg, #fce7f3 0%, #eff6ff 60%, #fdf2f8 100%);
  align-items: center; justify-content: center; padding: 24px;
  position: relative; overflow: hidden;
}
.login-blob {
  position: absolute; border-radius: 50%; pointer-events: none; filter: blur(60px); opacity: .25;
}
.lb1 { width:500px;height:500px;background:var(--pk4);top:-150px;right:-150px; }
.lb2 { width:400px;height:400px;background:var(--bl4);bottom:-120px;left:-120px; }
.lb3 { width:200px;height:200px;background:var(--pk3);bottom:100px;right:200px; }

.login-card {
  background: var(--wh); border-radius: var(--r-xl);
  padding: 44px 40px; width: 100%; max-width: 420px;
  box-shadow: var(--sh-lg); position: relative; z-index: 1;
  animation: slideUp .5s ease;
}
.login-top { text-align: center; margin-bottom: 28px; }
.login-icon-wrap {
  width: 76px; height: 76px; border-radius: 22px; margin: 0 auto 16px;
  background: linear-gradient(135deg, var(--pk5), var(--bl5));
  display: flex; align-items: center; justify-content: center;
  font-size: 34px; box-shadow: var(--sh-pk);
  animation: pulse 3s ease infinite;
}
.login-title { font-size: 19px; font-weight: 800; color: var(--g8); line-height: 1.35; }
.login-school { font-size: 13px; color: var(--g5); margin-top: 5px; }

.tab-row {
  display: flex; gap: 6px;
  background: var(--g1); border-radius: var(--r-sm);
  padding: 4px; margin-bottom: 24px;
}
.tab-btn {
  flex: 1; padding: 8px 4px; border: none; border-radius: 8px;
  font-family: inherit; font-size: 14px; font-weight: 500;
  color: var(--g5); cursor: pointer; transition: all .2s; background: transparent;
}
.tab-btn.on { background: var(--wh); color: var(--g8); box-shadow: var(--sh-sm); }

.fgroup { margin-bottom: 15px; }
.flabel { display: block; font-size: 13px; font-weight: 600; color: var(--g7); margin-bottom: 6px; }
.finput, .fselect {
  width: 100%; padding: 11px 14px;
  border: 1.5px solid var(--g2); border-radius: var(--r-sm);
  font-family: inherit; font-size: 14px; color: var(--g8);
  background: var(--wh); outline: none; transition: all .2s;
}
.finput:focus, .fselect:focus {
  border-color: var(--pk4);
  box-shadow: 0 0 0 3px rgba(236,72,153,.10);
}
.fselect { cursor: pointer; }
.btn-main {
  width: 100%; padding: 13px;
  background: linear-gradient(135deg, var(--pk5) 0%, var(--bl6) 100%);
  border: none; border-radius: var(--r-sm);
  font-family: inherit; font-size: 15px; font-weight: 700;
  color: var(--wh); cursor: pointer; transition: all .25s;
  box-shadow: var(--sh-pk); margin-top: 4px;
}
.btn-main:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(236,72,153,.35); }
.btn-main:active { transform: translateY(0); }

.login-hint {
  margin-top: 16px; padding: 12px 14px;
  background: var(--bl1); border-radius: var(--r-sm);
  font-size: 12px; color: var(--bl6); text-align: center;
}

/* ===== DASHBOARD ===== */
.wrap { max-width: 1100px; margin: 0 auto; padding: 28px 20px; }

.hero {
  border-radius: var(--r-lg); padding: 30px 32px;
  background: linear-gradient(135deg, var(--pk5) 0%, var(--bl6) 100%);
  color: var(--wh); margin-bottom: 24px; position: relative; overflow: hidden;
  animation: slideUp .4s ease;
}
.hero::before {
  content:''; position: absolute;
  top:-60px; right:-60px; width:220px; height:220px;
  background: rgba(255,255,255,.07); border-radius: 50%;
}
.hero::after {
  content:''; position: absolute;
  bottom:-80px; right:80px; width:280px; height:280px;
  background: rgba(255,255,255,.05); border-radius: 50%;
}
.hero-greet { font-size: 13px; opacity: .82; margin-bottom: 4px; }
.hero-name { font-size: 24px; font-weight: 800; margin-bottom: 6px; }
.hero-sub { font-size: 13px; opacity: .78; }
.hero-emoji {
  position: absolute; right: 32px; top: 50%; transform: translateY(-50%);
  font-size: 68px; opacity: .12; pointer-events: none;
}

.stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-bottom: 24px; }
.scard {
  background: var(--wh); border-radius: var(--r-md);
  padding: 18px; border: 1px solid var(--g2);
  display: flex; align-items: center; gap: 14px;
  box-shadow: var(--sh-sm); animation: slideUp .4s ease both;
}
.scard:nth-child(2){animation-delay:.06s}
.scard:nth-child(3){animation-delay:.12s}
.sicon {
  width: 44px; height: 44px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;
}
.sicon.pk { background: var(--pk1); }
.sicon.bl { background: var(--bl1); }
.sicon.gn { background: #f0fdf4; }
.snum { font-size: 22px; font-weight: 800; color: var(--g8); }
.slabel { font-size: 12px; color: var(--g5); margin-top: 2px; }

.sec-head {
  font-size: 17px; font-weight: 700; color: var(--g8);
  margin-bottom: 14px; display: flex; align-items: center; gap: 8px;
}

/* Unit cards */
.unit-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 18px; margin-bottom: 24px; }
.ucard {
  background: var(--wh); border-radius: var(--r-lg);
  border: 1.5px solid var(--g2); padding: 26px;
  cursor: pointer; transition: all .25s;
  position: relative; overflow: hidden;
  box-shadow: var(--sh-sm);
  animation: slideUp .4s ease both;
}
.ucard:nth-child(2){animation-delay:.08s}
.ucard:hover { transform: translateY(-5px); box-shadow: var(--sh-lg); }
.ucard.pk-card { border-top: 4px solid var(--pk4); }
.ucard.bl-card { border-top: 4px solid var(--bl5); }
.ucard:hover.pk-card { border-color: var(--pk5); box-shadow: var(--sh-pk); }
.ucard:hover.bl-card { border-color: var(--bl5); box-shadow: var(--sh-bl); }

.uicon {
  width: 54px; height: 54px; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; margin-bottom: 14px;
}
.pk-card .uicon { background: var(--pk1); }
.bl-card .uicon { background: var(--bl1); }

.utitle { font-size: 16px; font-weight: 700; color: var(--g8); margin-bottom: 3px; }
.usub { font-size: 13px; color: var(--g5); margin-bottom: 16px; }

.pbar-wrap { background: var(--g1); border-radius: 99px; height: 7px; margin-bottom: 7px; overflow: hidden; }
.pbar-fill { height: 100%; border-radius: 99px; transition: width .7s cubic-bezier(.4,0,.2,1); }
.pk-fill { background: linear-gradient(90deg, var(--pk5), var(--pk3)); }
.bl-fill { background: linear-gradient(90deg, var(--bl6), var(--bl3)); }
.plabel { font-size: 12px; color: var(--g5); display: flex; justify-content: space-between; }

.pills { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
.pill {
  padding: 3px 10px; border-radius: 99px;
  font-size: 11px; font-weight: 500; cursor: pointer; transition: all .2s;
}
.pill.done { background: var(--pk2); color: var(--pk6); }
.pill.todo { background: var(--g1); color: var(--g5); }
.pill:hover { transform: scale(1.05); }

/* Satisfaction card */
.sat-cta {
  background: var(--wh); border-radius: var(--r-lg);
  border: 1.5px solid var(--pk3); padding: 20px 24px;
  cursor: pointer; transition: all .25s;
  display: flex; align-items: center; gap: 16px;
  box-shadow: var(--sh-sm);
}
.sat-cta:hover { transform: translateY(-3px); box-shadow: var(--sh-pk); }
.sat-icon { font-size: 36px; }
.sat-arrow { margin-left: auto; font-size: 22px; color: var(--g3); }

/* Teacher intro link */
.teacher-cta {
  background: var(--wh); border-radius: var(--r-md);
  border: 1.5px solid var(--bl3); padding: 16px 20px;
  cursor: pointer; transition: all .25s;
  display: flex; align-items: center; gap: 14px;
  box-shadow: var(--sh-sm); margin-top: 12px;
}
.teacher-cta:hover { transform: translateY(-3px); box-shadow: var(--sh-bl); }

/* ===== UNIT PAGE ===== */
.page-hdr {
  background: var(--wh); border-bottom: 1px solid var(--g2);
  padding: 18px 24px; box-shadow: var(--sh-sm);
}
.breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--g5); margin-bottom: 6px; }
.breadcrumb a { color: var(--pk5); cursor: pointer; text-decoration: none; }
.breadcrumb a:hover { text-decoration: underline; }
.page-title { font-size: 20px; font-weight: 800; color: var(--g8); }

.lgrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr)); gap: 14px; padding: 22px 20px; max-width: 1100px; margin: 0 auto; }
.lcard {
  background: var(--wh); border-radius: var(--r-md);
  border: 1.5px solid var(--g2); padding: 18px;
  display: flex; gap: 14px; cursor: pointer;
  transition: all .25s; animation: slideUp .35s ease both;
}
.lcard:hover { border-color: var(--pk3); box-shadow: var(--sh-md); transform: translateY(-3px); }
.lcard.done { background: var(--pk1); border-color: var(--pk2); }
.lnum {
  width: 40px; height: 40px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; flex-shrink: 0;
}
.lnum.pk { background: var(--pk2); color: var(--pk6); }
.lnum.bl { background: var(--bl2); color: var(--bl6); }
.lnum.dn { background: var(--pk5); color: var(--wh); }
.linfo {}
.ltitle { font-size: 14px; font-weight: 700; color: var(--g8); margin-bottom: 4px; }
.lmeta { font-size: 12px; color: var(--g5); }
.badge {
  display: inline-flex; align-items: center; gap: 3px;
  padding: 2px 8px; border-radius: 99px;
  font-size: 11px; font-weight: 500; margin-top: 7px; margin-right: 4px;
}
.badge-done { background: var(--pk2); color: var(--pk6); }
.badge-todo { background: var(--g1); color: var(--g5); }
.badge-home { background: var(--bl1); color: var(--bl6); }
.badge-class { background: #f0fdf4; color: #15803d; }

/* ===== LESSON PAGE ===== */
.lesson-layout { max-width: 980px; margin: 0 auto; padding: 22px 20px; display: grid; grid-template-columns: 1fr 300px; gap: 20px; }
.lesson-main {}
.lesson-side {}

/* Video */
.video-box {
  background: #0d0d1a; border-radius: var(--r-md);
  overflow: hidden; aspect-ratio: 16/9; margin-bottom: 18px; position: relative;
}
.video-ph {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;
  color: rgba(255,255,255,.65);
}
.vplay-btn {
  width: 64px; height: 64px; border-radius: 50%;
  background: linear-gradient(135deg, var(--pk5), var(--bl5));
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; cursor: pointer; transition: transform .2s;
  box-shadow: var(--sh-pk);
}
.vplay-btn:hover { transform: scale(1.1); }
.vframe { width: 100%; height: 100%; border: none; display: none; }
.vframe.on { display: block; }

/* Content cards */
.lccard {
  background: var(--wh); border-radius: var(--r-md);
  border: 1px solid var(--g2); overflow: hidden; margin-bottom: 16px;
  box-shadow: var(--sh-sm);
}
.lccard-hdr {
  padding: 14px 18px; border-bottom: 1px solid var(--g1);
  font-weight: 700; font-size: 14px; color: var(--g8);
  display: flex; align-items: center; gap: 8px;
  background: linear-gradient(135deg, var(--pk1), var(--bl1));
}
.lccard-body { padding: 18px; }

.sum-list { list-style: none; }
.sum-list li {
  padding: 7px 0; border-bottom: 1px solid var(--g0);
  display: flex; gap: 10px; font-size: 14px; color: var(--g7);
}
.sum-list li:last-child { border-bottom: none; }
.sdot {
  width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-top: 7px;
  background: linear-gradient(135deg, var(--pk4), var(--bl4));
}

/* Quiz */
.quiz-q { font-size: 14px; font-weight: 600; color: var(--g8); margin-bottom: 10px; }
.quiz-opts { display: flex; flex-direction: column; gap: 7px; margin-bottom: 8px; }
.quiz-opt {
  padding: 9px 14px; border: 1.5px solid var(--g2);
  border-radius: var(--r-sm); cursor: pointer; font-size: 14px;
  color: var(--g7); transition: all .2s; font-family: inherit;
  background: var(--wh); text-align: left;
}
.quiz-opt:hover:not(:disabled) { border-color: var(--pk3); background: var(--pk1); }
.quiz-opt.correct { border-color: var(--green); background: #f0fdf4; color: #065f46; }
.quiz-opt.wrong { border-color: var(--red); background: #fef2f2; color: #991b1b; }
.quiz-fb {
  margin-top: 8px; padding: 9px 12px; border-radius: var(--r-sm);
  font-size: 13px; display: none;
}
.quiz-fb.show { display: block; }
.quiz-fb.ok { background: #f0fdf4; color: #065f46; }
.quiz-fb.no { background: #fef2f2; color: #991b1b; }
.quiz-sep { border: none; border-top: 1px solid var(--g1); margin: 16px 0; }

/* Assignment */
.assign-box {
  background: var(--wh); border-radius: var(--r-md);
  border: 1.5px solid var(--pk3); overflow: hidden; box-shadow: var(--sh-sm);
}
.assign-hdr {
  background: linear-gradient(135deg, var(--pk1), var(--bl1));
  padding: 14px 18px; border-bottom: 1px solid var(--pk2);
  display: flex; align-items: flex-start; gap: 10px;
}
.assign-title { font-weight: 700; font-size: 15px; color: var(--g8); margin-bottom: 4px; }
.assign-body { padding: 18px; }
.assign-desc { font-size: 14px; color: var(--g6); margin-bottom: 14px; line-height: 1.8; }
.steps { background: var(--g0); border-radius: var(--r-sm); padding: 14px; margin-bottom: 16px; }
.step { display: flex; gap: 10px; font-size: 13px; color: var(--g7); padding: 5px 0; }
.step-n {
  width: 22px; height: 22px; border-radius: 50%;
  background: linear-gradient(135deg, var(--pk5), var(--bl5));
  color: var(--wh); display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; flex-shrink: 0;
}
.txtarea {
  width: 100%; padding: 11px 13px; min-height: 96px;
  border: 1.5px solid var(--g2); border-radius: var(--r-sm);
  font-family: inherit; font-size: 14px; resize: vertical; outline: none; transition: all .2s;
}
.txtarea:focus { border-color: var(--pk4); box-shadow: 0 0 0 3px rgba(236,72,153,.08); }
.upload-area {
  border: 2px dashed var(--pk3); border-radius: var(--r-sm);
  padding: 22px; text-align: center; cursor: pointer;
  background: var(--pk1); transition: all .2s; margin: 12px 0;
}
.upload-area:hover { border-color: var(--pk5); background: var(--pk2); }
.uico { font-size: 26px; margin-bottom: 6px; }
.utxt { font-size: 13px; color: var(--g6); }
.btn-submit {
  width: 100%; padding: 12px; background: linear-gradient(135deg, var(--pk5), var(--bl6));
  border: none; border-radius: var(--r-sm);
  font-family: inherit; font-size: 14px; font-weight: 700;
  color: var(--wh); cursor: pointer; transition: all .25s; margin-top: 10px;
}
.btn-submit:hover { transform: translateY(-2px); box-shadow: var(--sh-pk); }

/* Sidebar */
.scrd {
  background: var(--wh); border-radius: var(--r-md);
  border: 1px solid var(--g2); overflow: hidden; margin-bottom: 14px; box-shadow: var(--sh-sm);
}
.scrd-hdr {
  padding: 12px 16px; border-bottom: 1px solid var(--g1);
  font-weight: 700; font-size: 13px; color: var(--g8);
  background: linear-gradient(135deg, var(--pk1), var(--bl1));
}
.scrd-body { padding: 14px; }
.lnav-item {
  display: flex; align-items: center; gap: 9px; padding: 7px 9px;
  border-radius: 8px; cursor: pointer; transition: all .2s;
  font-size: 13px; color: var(--g6); margin-bottom: 3px;
}
.lnav-item:hover { background: var(--g0); color: var(--g8); }
.lnav-item.cur { background: var(--pk1); color: var(--pk6); font-weight: 600; }
.ndot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.ndot.done { background: var(--pk5); }
.ndot.cur { background: var(--bl5); }
.ndot.todo { background: var(--g3); }

/* ===== SATISFACTION ===== */
.sat-wrap { max-width: 680px; margin: 0 auto; padding: 28px 20px; }
.sat-hdr { text-align: center; margin-bottom: 28px; animation: slideUp .4s ease; }
.sat-icon-big {
  width: 78px; height: 78px; border-radius: 22px; margin: 0 auto 14px;
  background: linear-gradient(135deg, var(--pk5), var(--bl5));
  display: flex; align-items: center; justify-content: center;
  font-size: 34px; box-shadow: var(--sh-pk);
}
.sat-title { font-size: 20px; font-weight: 800; color: var(--g8); margin-bottom: 6px; }
.sat-desc { font-size: 13px; color: var(--g5); line-height: 1.7; }

.sat-form {
  background: var(--wh); border-radius: var(--r-lg);
  padding: 28px; box-shadow: var(--sh-md); border: 1px solid var(--g2);
  animation: slideUp .4s .05s ease both;
}
.sat-item { margin-bottom: 26px; padding-bottom: 22px; border-bottom: 1px solid var(--g1); }
.sat-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.sat-q { font-size: 14px; font-weight: 600; color: var(--g8); margin-bottom: 12px; }
.rating-row { display: flex; gap: 7px; }
.rbtn {
  flex: 1; padding: 10px 4px; border: 1.5px solid var(--g2);
  border-radius: 10px; background: var(--wh); cursor: pointer; transition: all .2s;
  text-align: center; font-family: inherit;
}
.rbtn .rn { font-size: 15px; font-weight: 800; color: var(--g4); display: block; }
.rbtn .rl { font-size: 10px; color: var(--g4); display: block; margin-top: 2px; }
.rbtn:hover,.rbtn.on { border-color: var(--pk4); background: var(--pk1); }
.rbtn.on .rn { color: var(--pk6); }
.rbtn.on .rl { color: var(--pk5); }
.scale-lbl { display: flex; justify-content: space-between; font-size: 11px; color: var(--g4); margin-top: 5px; }

.btn-sat {
  display: block; width: 100%; max-width: 300px; margin: 20px auto 0;
  padding: 13px; background: linear-gradient(135deg, var(--pk5), var(--bl6));
  border: none; border-radius: var(--r-sm);
  font-family: inherit; font-size: 15px; font-weight: 700;
  color: var(--wh); cursor: pointer; transition: all .25s;
  box-shadow: var(--sh-pk);
}
.btn-sat:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(236,72,153,.35); }

/* ===== TEACHER PANEL ===== */
.teacher-wrap { max-width: 1200px; margin: 0 auto; padding: 24px 20px; }
.teacher-tabs {
  display: flex; gap: 4px; background: var(--g1);
  border-radius: 12px; padding: 4px; margin-bottom: 22px; width: fit-content;
}
.ttab {
  padding: 8px 18px; border: none; background: transparent;
  border-radius: 9px; font-family: inherit; font-size: 13px; font-weight: 500;
  color: var(--g5); cursor: pointer; transition: all .2s;
}
.ttab.on { background: var(--wh); color: var(--g8); box-shadow: var(--sh-sm); }

.tsec { display: none; }
.tsec.on { display: block; }

/* Efficiency banner */
.eff-banner {
  border-radius: var(--r-md); padding: 22px 24px;
  background: linear-gradient(135deg, var(--pk5), var(--bl6));
  color: var(--wh); margin-bottom: 20px;
  display: grid; grid-template-columns: 1fr 1px 1fr 1px 1fr; gap: 20px; align-items: center;
}
.eff-div { background: rgba(255,255,255,.2); height: 100%; }
.eff-item { text-align: center; }
.eff-n { font-size: 30px; font-weight: 800; }
.eff-l { font-size: 12px; opacity: .82; margin-top: 4px; }

/* Tables */
.tbl-wrap { background: var(--wh); border-radius: var(--r-md); overflow: auto; box-shadow: var(--sh-sm); border: 1px solid var(--g2); }
.dtbl { width: 100%; border-collapse: separate; border-spacing: 0; }
.dtbl th { padding: 11px 14px; background: var(--g0); font-size: 12px; font-weight: 700; color: var(--g6); text-align: left; border-bottom: 1px solid var(--g2); white-space: nowrap; }
.dtbl td { padding: 11px 14px; font-size: 13px; color: var(--g7); border-bottom: 1px solid var(--g0); white-space: nowrap; }
.dtbl tr:last-child td { border-bottom: none; }
.dtbl tr:hover td { background: var(--g0); }

.stag {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 9px; border-radius: 99px; font-size: 11px; font-weight: 600;
}
.stag.ok { background: var(--pk2); color: var(--pk6); }
.stag.no { background: var(--g1); color: var(--g5); }
.stag.pt { background: var(--bl1); color: var(--bl6); }

/* Rubric input */
.rinput {
  width: 44px; padding: 4px; text-align: center;
  border: 1px solid var(--g2); border-radius: 6px;
  font-family: inherit; font-size: 13px; outline: none;
}
.rinput:focus { border-color: var(--pk4); }

.rscore {
  display: inline-flex; align-items: center; justify-content: center;
  width: 26px; height: 26px; border-radius: 7px;
  font-size: 12px; font-weight: 700;
}
.rs4 { background: #dcfce7; color: #15803d; }
.rs3 { background: var(--bl1); color: var(--bl6); }
.rs2 { background: #fef9c3; color: #a16207; }
.rs1 { background: #fee2e2; color: #dc2626; }

/* Toolbar */
.tbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
.tbar-l { display: flex; gap: 6px; flex-wrap: wrap; }

.btn-2nd {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 16px; border: 1.5px solid var(--g2);
  border-radius: var(--r-sm); background: var(--wh);
  font-family: inherit; font-size: 13px; font-weight: 500;
  color: var(--g7); cursor: pointer; transition: all .2s;
}
.btn-2nd:hover { border-color: var(--pk3); color: var(--pk6); }
.btn-exp {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 16px; border: none;
  border-radius: var(--r-sm);
  background: linear-gradient(135deg, var(--pk5), var(--bl6));
  font-family: inherit; font-size: 13px; font-weight: 600;
  color: var(--wh); cursor: pointer; transition: all .2s;
}
.btn-exp:hover { transform: translateY(-1px); box-shadow: var(--sh-pk); }

.filt-btn {
  padding: 6px 14px; border: 1.5px solid var(--g2);
  border-radius: 99px; background: var(--wh);
  font-family: inherit; font-size: 13px; color: var(--g6);
  cursor: pointer; transition: all .2s;
}
.filt-btn.on { border-color: var(--pk4); background: var(--pk1); color: var(--pk6); }

/* Manage form */
.mform {
  display: none; background: var(--wh); border-radius: var(--r-md);
  padding: 22px; box-shadow: var(--sh-sm); border: 1px solid var(--g2); margin-bottom: 18px;
}
.mform.open { display: block; }
.mform-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(180px,1fr)); gap: 12px; }

/* ===== TEACHER INTRO ===== */
.ti-wrap { max-width: 780px; margin: 0 auto; padding: 28px 20px; }
.ti-card {
  background: var(--wh); border-radius: var(--r-xl);
  overflow: hidden; box-shadow: var(--sh-lg); border: 1px solid var(--g2);
  animation: slideUp .4s ease;
}
.ti-cover {
  height: 160px;
  background: linear-gradient(135deg, var(--pk4), var(--bl6));
  position: relative;
}
.ti-cover::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at 20% 50%, rgba(255,255,255,.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 20%, rgba(255,255,255,.08) 0%, transparent 40%);
}
.ti-av-wrap { position: absolute; bottom: -38px; left: 30px; }
.ti-av {
  width: 76px; height: 76px; border-radius: 20px;
  background: linear-gradient(135deg, var(--pk3), var(--bl4));
  border: 4px solid var(--wh); display: flex; align-items: center;
  justify-content: center; font-size: 30px; box-shadow: var(--sh-md);
}
.ti-body { padding: 54px 30px 30px; }
.ti-name { font-size: 22px; font-weight: 800; color: var(--g8); margin-bottom: 3px; }
.ti-role { font-size: 13px; color: var(--g5); margin-bottom: 18px; }
.ti-metas { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; }
.ti-meta {
  display: flex; align-items: center; gap: 6px;
  font-size: 13px; color: var(--g6);
  background: var(--g0); padding: 5px 12px; border-radius: 99px;
}
.ti-desc { font-size: 14px; color: var(--g6); line-height: 1.9; margin-bottom: 22px; }
.ti-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; }
.ti-gitem {
  background: linear-gradient(135deg, var(--pk1), var(--bl1));
  border-radius: var(--r-sm); padding: 13px 14px;
}
.ti-gl { font-size: 11px; color: var(--g5); margin-bottom: 3px; }
.ti-gv { font-size: 13px; font-weight: 700; color: var(--g8); }

/* ===== TOAST ===== */
.toast {
  position: fixed; bottom: 22px; right: 22px;
  padding: 11px 18px; border-radius: 12px;
  font-size: 14px; color: var(--wh);
  background: var(--g8); box-shadow: var(--sh-lg);
  z-index: 9999; transform: translateY(80px); opacity: 0; transition: all .3s;
  display: flex; align-items: center; gap: 8px; max-width: 360px;
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.ok { background: linear-gradient(135deg, var(--green), #059669); }
.toast.err { background: linear-gradient(135deg, var(--red), #dc2626); }

/* ===== RESPONSIVE ===== */
@media(max-width:768px){
  .stats { grid-template-columns: 1fr; }
  .unit-grid { grid-template-columns: 1fr; }
  .lesson-layout { grid-template-columns: 1fr; }
  .lesson-side { display: none; }
  .eff-banner { grid-template-columns: 1fr; }
  .eff-div { display: none; }
  .ti-grid { grid-template-columns: 1fr; }
  .hero-emoji { display: none; }
  .login-card { padding: 32px 22px; }
  .teacher-tabs { flex-wrap: wrap; }
}

/* Scroll to top smooth */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--g1); }
::-webkit-scrollbar-thumb { background: var(--pk3); border-radius: 99px; }
</style>
