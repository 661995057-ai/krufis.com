/* ===== NAVIGATION ===== */
function goTo(pg){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+pg).classList.add('active');
  window.scrollTo(0,0);
}
function logout(){ user=null; goTo('login'); }
function backFromLesson(){ openUnit(curUnit); }

/* ===== LOGIN ===== */
function switchTab(type,btn){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('frm-student').style.display = type==='student'?'block':'none';
  document.getElementById('frm-teacher').style.display = type==='teacher'?'block':'none';
}

function loginSt(){
  const u=document.getElementById('su').value.trim();
  const p=document.getElementById('sp').value.trim();
  if(!u||!p){toast('กรุณากรอก username และรหัสผ่าน','err');return;}
  const st=studDB.find(s=>s.user===u&&s.pass===p);
